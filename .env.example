# --- Convallax maker credentials ---
# API key from the Convallax dashboard (Settings -> API Keys). Authorizes quoting only; cannot move funds.
CONVALLAX_API_KEY=

# Private key for the maker wallet that signs EIP-712 settlement orders.
# MUST correspond to wallet 0xf8D0dead28cBB8C257E4f2dCf6c89c52b97fc0F3 (maker id mm_37a2449f4b).
# Not required to run the Phase 1 read-only listener; required for approvals/signing.
MM_PRIVATE_KEY=

# --- Network / endpoints (defaults target Convallax production + Polygon Amoy testnet) ---
API_BASE=https://api.convallax.com
WS_BASE=wss://api.convallax.com
RPC_URL=https://rpc-amoy.polygon.technology

# --- Logging ---
LOG_LEVEL=info
# Set LOG_JSON=1 for machine-readable JSON logs (recommended in prod).
LOG_JSON=
